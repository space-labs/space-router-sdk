{
  "name": "spacerouter",
  "version": "0.1.0",
  "description": "JavaScript SDK for the Space Router residential proxy network",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
